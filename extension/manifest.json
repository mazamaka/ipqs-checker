{
  "manifest_version": 2,
  "name": "IPQS Fingerprint Checker",
  "version": "1.2",
  "description": "Автоматический сбор IPQS fingerprint с indeed.com",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "browsingData",
    "webRequest",
    "webRequestBlocking",
    "https://secure.indeed.com/*",
    "https://*.indeed.com/*",
    "https://fn.us.ipqscdn.com/*",
    "https://*.ipqscdn.com/*",
    "https://check-ipqs.farm-mafia.cash/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://secure.indeed.com/*", "https://*.indeed.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "IPQS Checker"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
