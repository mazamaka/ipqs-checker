# IPQS API Key (обязательно)
IPQS_API_KEY=your_ipqs_api_key_here

# Домен для IPQS (по умолчанию indeed.com)
IPQS_DOMAIN=indeed.com

# Токен для админ-операций (DELETE /api/visitors)
ADMIN_TOKEN=your_secure_token_here

# Порт (по умолчанию 8000)
PORT=8000

# Количество воркеров (по умолчанию 1)
WORKERS=1
