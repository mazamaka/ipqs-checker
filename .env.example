# ===============================
# IPQS Checker - Environment
# ===============================

# IPQS API (обязательно для проверок)
IPQS_API_KEY=your_ipqs_api_key_here
IPQS_DOMAIN=indeed.com

# Server
PORT=8000
WORKERS=1

# ===============================
# PostgreSQL Database
# ===============================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=ipqs
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=ipqs_checker

# ===============================
# Admin Panel
# ===============================
# Пароль для входа в админку (/admin)
ADMIN_PASSWORD=your_admin_password_here

# Секрет для JWT токенов (сгенерируй случайную строку)
ADMIN_TOKEN_SECRET=your_random_secret_key_here

# Legacy: токен для DELETE /api/visitors (опционально)
ADMIN_TOKEN=
