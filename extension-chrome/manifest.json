{
  "manifest_version": 3,
  "name": "IPQS Fingerprint Checker",
  "version": "1.2",
  "description": "Автоматический сбор IPQS fingerprint с indeed.com",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "browsingData",
    "scripting"
  ],
  "host_permissions": [
    "https://secure.indeed.com/*",
    "https://*.indeed.com/*",
    "https://fn.us.ipqscdn.com/*",
    "https://*.ipqscdn.com/*",
    "https://check-ipqs.farm-mafia.cash/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://secure.indeed.com/*", "https://*.indeed.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "IPQS Checker"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://*.indeed.com/*"]
    }
  ]
}
