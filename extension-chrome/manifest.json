{
  "manifest_version": 3,
  "name": "Fingerprint Checker",
  "version": "4.8",
  "description": "Проверка fingerprint через IPQS, Fingerprint Pro, CreepJS и AntCpt",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "browsingData",
    "scripting"
  ],
  "host_permissions": [
    "https://secure.indeed.com/*",
    "https://*.indeed.com/*",
    "https://fn.us.ipqscdn.com/*",
    "https://*.ipqscdn.com/*",
    "https://fingerprint.com/*",
    "https://*.fingerprint.com/*",
    "https://check.maxbob.xyz/*",
    "https://abrahamjuliot.github.io/*",
    "https://antcpt.com/*",
    "https://*.antcpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://secure.indeed.com/*", "https://*.indeed.com/*"],
      "js": ["content-ipqs.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://fingerprint.com/*", "https://*.fingerprint.com/*"],
      "js": ["content-fp.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://abrahamjuliot.github.io/creepjs/*"],
      "js": ["content-creep.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://antcpt.com/score_detector/*", "https://*.antcpt.com/score_detector/*"],
      "js": ["content-antcpt.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Fingerprint Checker"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://*.indeed.com/*"]
    },
    {
      "resources": ["injected-fp.js"],
      "matches": ["https://fingerprint.com/*", "https://*.fingerprint.com/*"]
    },
    {
      "resources": ["injected-antcpt.js"],
      "matches": ["https://antcpt.com/*", "https://*.antcpt.com/*"]
    }
  ]
}
